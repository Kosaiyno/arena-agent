PORT=4000
RPC_URL=http://127.0.0.1:8545
PRIVATE_KEY=replace_with_operator_private_key
CONTRACT_ADDRESS=replace_with_contract_address
POLL_INTERVAL_MS=5000
DEFAULT_PAYOUTS=50,30,20
STATE_FILE_PATH=./data/state.json
SUPPORTED_TOKENS_JSON=[{"symbol":"OKB","name":"OKB","address":null,"decimals":18,"kind":"native","rateToNative":1},{"symbol":"USDC","name":"USD Coin","address":null,"decimals":6,"kind":"erc20","rateToNative":0.0005555556},{"symbol":"USDT","name":"Tether","address":null,"decimals":6,"kind":"erc20","rateToNative":0.0005555556},{"symbol":"WOKB","name":"Wrapped OKB","address":null,"decimals":18,"kind":"erc20","rateToNative":1}]

# X Layer network (chain 196 mainnet, 195 testnet)
APP_CHAIN_ID=195

# Uniswap Trading API (https://docs.uniswap.org/)
UNISWAP_API_KEY=
UNISWAP_API_URL=https://trade-api.gateway.uniswap.org/v1

# OKX / Onchain OS API (https://www.okx.com/web3/build/docs)
ONCHAIN_OS_API_KEY=
ONCHAIN_OS_SECRET_KEY=
ONCHAIN_OS_PASSPHRASE=

# OpenAI-compatible LLM for operator chat (optional, falls back to rules)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4.1-mini

# x402 Payment Required flow (enabled by default)
X402_ENABLED=true

# OKLink (for contract verification on X Layer)
OKLINK_API_KEY=

# X Layer RPC overrides (optional, defaults are public endpoints)
XLAYER_TESTNET_RPC_URL=https://testrpc.xlayer.tech
XLAYER_RPC_URL=https://rpc.xlayer.tech
